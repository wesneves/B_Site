{{ define "main" }}
<section class="hero">
    <div class="container">
        <h1>Explorando o Universo R</h1>
        <p>Curadoria, inteligência de dados e as últimas fronteiras da computação estatística.</p>
        <div style="margin-top: 30px;">
            <a href="/postagens" style="background: var(--accent); color: white; padding: 12px 25px; text-decoration: none; border-radius: 5px; font-weight: 600; font-size: 0.9rem;">Ver Todas as Postagens</a>
        </div>
    </div>
</section>

<section class="container" style="margin-bottom: 80px;">
    <div class="feature-grid">
        <div class="feature-card">
            <h3 style="font-size: 1.2rem;">Ciência de Dados</h3>
            <p style="font-size: 0.9rem; text-align: center;">Modelagem avançada e tratamento de grandes volumes de dados.</p>
        </div>
        <div class="feature-card">
            <h3 style="font-size: 1.2rem;">Visualização</h3>
            <p style="font-size: 0.9rem; text-align: center;">Criação de gráficos autorais e dashboards interativos com Shiny.</p>
        </div>
        <div class="feature-card">
            <h3 style="font-size: 1.2rem;">Educação</h3>
            <p style="font-size: 0.9rem; text-align: center;">Treinamentos in-company e produção de conteúdo técnico.</p>
        </div>
    </div>

    <h2 style="border-left: 4px solid var(--accent); padding-left: 15px; margin-bottom: 30px;">Radar R: O que acompanhar</h2>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px;">
        
        <div class="resource-box">
            <h3 style="font-family: var(--font-sans); font-size: 1.1rem; color: var(--accent);">Versão Atual do R</h3>
            <p style="font-size: 0.9rem;">Fique de olho no <strong id="r-version">R carregando...</strong>. Mantenha sempre o seu R atualizado para acompanhar as melhorias e novidades.</p>
            <a href="https://cran.r-project.org/doc/manuals/r-release/NEWS.html" target="_blank" style="font-size: 0.8rem; font-weight: bold; text-decoration: none; color: var(--accent);">Ler NEWS oficial →</a>
        </div>

        <div class="resource-box">
            <h3 style="font-family: var(--font-sans); font-size: 1.1rem; color: var(--accent);">CRAN Task Views</h3>
            <p style="font-size: 0.9rem;">O mapa definitivo para pacotes. As listas de tarefas do CRAN visam orientar sobre quais pacotes da Rede Abrangente de Arquivos R (CRAN) são relevantes para tarefas relacionadas a um determinado tópico..</p>
            <a href="https://cran.r-project.org/web/views/" target="_blank" style="font-size: 0.8rem; font-weight: bold; text-decoration: none; color: var(--accent);">Explorar Task Views →</a>
        </div>
    </div>
</section>

<section class="container community-section">
    <div style="max-width: 800px; margin: 0 auto;">
        <h2 style="margin-bottom: 20px;">Curiosidades e Comunidade</h2>
        <p style="font-size: 1.1rem;">O R é movido pela comunidade. Se você busca inspiração diária, o <strong>R-Bloggers</strong> e a <strong>R Weekly</strong> são paradas obrigatórias.</p>
        <div style="display: flex; justify-content: center; gap: 20px; margin-top: 30px;">
            <a href="https://www.r-bloggers.com/" target="_blank" class="tag" style="padding: 10px 20px; border: 1px solid var(--accent);">R-Bloggers</a>
            <a href="https://rweekly.org/" target="_blank" class="tag" style="padding: 10px 20px; border: 1px solid var(--accent);">R Weekly</a>
        </div>
    </div>
</section>

<script>
    async function fetchRVersion() {
        try {
            const response = await fetch('https://r-pkg.org/api/v1/r-version');
            const data = await response.json();
            if (data && data.version) {
                document.getElementById('r-version').innerText = 'R ' + data.version;
            }
        } catch (error) {
            console.error('Erro ao buscar versão do R:', error);
            document.getElementById('r-version').innerText = 'R 4.5.3'; 
        }
    }
    fetchRVersion();
</script>
{{ end }}